# CustAPI REST API base URL (server-side only).
# Point this at the custapi QA environment for local development and
# integration testing, or at the default cluster service in production.
CUSTAPI_URL=http://custapi.mapfox.hoshina.san/api/v1

# Experiment Manager REST API base URL (server-side only). Used by the
# /internal/experiment onboarding + editor flows.
EXPERIMENT_MANAGER_URL=http://experiment-manager.mapfox.hoshina.san

# Ticketing Service base URL (server-side only). Used by the experiment
# listing/workspace pages. The generated client appends /api/v1/...
TICKETING_URL=http://ticketing-service.mapfox.hoshina.san

# Redis connection string (server-side only). Backs the collaborative editing
# layer for the experiment workspace: presence, soft field locks, the live
# value buffer, and pub/sub fan-out across pods. For local dev, start it with
# `docker compose -f docker-compose.dev.yml up -d` (repo root).
REDIS_URL=redis://localhost:6379

# Secret used to sign and verify the session JWT cookie. Required in production.
JWT_SECRET=change-me

# Optional override for the session cookie Secure flag.
# Defaults to true in production. Set false for local HTTP development.
SESSION_COOKIE_SECURE=false

# Optional explicit public origin (scheme + host) used to build absolute URLs,
# such as the QR-encoded sample check-in link printed by requesters. When unset
# it's derived from the request's forwarded host/proto headers (correct behind
# Cloudflare). Set it only if that derivation is wrong for your setup.
# APP_ORIGIN=https://chemfox.example.com

# External organization portal base URL. Org names in the user menu link here
# (opens in a new tab). Path appended: /organization/{orgId}
ORGANIZATION_PORTAL_URL=https://your-org-portal.example.com
